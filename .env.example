# HTTP server
HOST=0.0.0.0
PORT=8080
SITE_DIR=dist
DATA_DIR=server-data

# Change this before exposing the admin page.
ADMIN_TOKEN=change-me-to-a-long-random-token

# Student submission limits
MAX_BODY_BYTES=5242880
MAX_SUBMISSION_ATTACHMENTS=3
MAX_ATTACHMENT_DATA_URL_BYTES=1048576
POST_RATE_WINDOW_MS=600000
POST_RATE_LIMIT=20
